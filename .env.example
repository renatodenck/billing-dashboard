# Neon Postgres connection string
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# OpenAI admin key with Usage API Read scope
OPENAI_ADMIN_KEY=sk-admin-...

# Anthropic admin key (Cost Report API). Created at https://console.anthropic.com/settings/admin-keys
ANTHROPIC_ADMIN_KEY=sk-ant-admin01-...

# Meta WhatsApp Business — pricing_analytics endpoint reads dispatch costs.
# Token needs scope `whatsapp_business_management`.
# Two pairs because B2C and B2B usually live in separate Business Managers.
META_ACCESS_TOKEN=EAA...                # B2C System User token
META_WABA_ID=1464543518654748           # B2C WABA (e.g. "Bru SDR")
META_ACCESS_TOKEN_B2B=EAA...            # B2B System User token (different BM)
META_WABA_B2B_ID=967410155643603        # B2B WABA (e.g. "PSA | Manu")

# HubSpot (for lead count + CPO). Uses the Leads object (not Deals).
# We count leads that ENTERED the given stage during the period (date entered stage).
HUBSPOT_TOKEN=pat-na1-...
HUBSPOT_LEAD_PIPELINE=B2C | Leads de produtos palestrantes
HUBSPOT_LEAD_STAGE=Qualificado
HUBSPOT_LEAD_PIPELINE_B2B=B2B | Leads de Curadoria
HUBSPOT_LEAD_STAGE_B2B=Qualificado

# Optional. USD→BRL exchange rate. Only used if OpenAI and Meta return different currencies.
# Today (Meta = WhatsApp dispatch billed in USD) this isn't applied. Default: 5.0.
NEXT_PUBLIC_USD_TO_BRL=5.0

# Basic auth for the dashboard (shared with team)
DASHBOARD_USER=team
DASHBOARD_PASSWORD=change-me

# Vercel sets this automatically; use it locally to test the cron endpoint
CRON_SECRET=any-long-random-string
